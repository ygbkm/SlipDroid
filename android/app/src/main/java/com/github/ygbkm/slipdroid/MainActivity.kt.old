class MainActivity : ComponentActivity() {

	val tag = "mainAcTiViTy"

	override fun onCreate(savedInstanceState: Bundle?) {
		super.onCreate(savedInstanceState)
		enableEdgeToEdge()
		ActivityCompat.requestPermissions(
			this,
			arrayOf(Manifest.permission.RECORD_AUDIO),
			0,
		)
		if (Build.VERSION.SDK_INT >= sdk33_Tiramisu) {
			ActivityCompat.requestPermissions(
				this,
				arrayOf(Manifest.permission.POST_NOTIFICATIONS),
				0,
			)
		}
		setContent {
			SlipDroidTheme {
				Column(
					modifier = Modifier.fillMaxSize(),
					horizontalAlignment = Alignment.CenterHorizontally,
					verticalArrangement = Arrangement.Center,
				) {
					Button(onClick = { audioServiceAction(AudioService.Action.START) }) {
						Text(text = "Start audio service")
					}
					Button(onClick = { audioServiceAction(AudioService.Action.STOP) }) {
						Text(text = "Stop audio service")
					}
				}
				//Scaffold(modifier = Modifier.fillMaxSize()) { innerPadding ->
				//	Greeting(
				//		name = "Android",
				//		modifier = Modifier.padding(innerPadding)
				//	)
				//}
			}
		}

		GlobalScope.launch {
			delay(3000L)
			Log.d(tag, "coroutine says hello from ${Thread.currentThread().name}")
		}
		Log.d(tag, "hello from ${Thread.currentThread().name}")
	}

	private fun audioServiceAction(action: AudioService.Action) {
		val intent = Intent(applicationContext, AudioService::class.java)
		intent.action = action.toString()
		startService(intent)
	}
}

@Composable
fun Greeting(name: String, modifier: Modifier = Modifier) {
	Text(
		text = "Hello $name!",
		modifier = modifier
	)
}

