const val sdk33_Tiramisu = 33
const val sdk34_UpsideDownCake = 34

const val notifChannelID_audioService = "audio_service"

fun installAndRunBinary(context: Context) {

	val binaryName = "slipstream-client"
	val internalPath = File(context.filesDir, binaryName)

	// 1. Copy from assets to internal storage
	context.assets.open("bin/$binaryName").use { input ->
		FileOutputStream(internalPath).use { output ->
			input.copyTo(output)
		}
	}

	// 2. IMPORTANT: Set execution permissions
	internalPath.setExecutable(true)

	// 3. Execute
	thread {
		try {
			val process = ProcessBuilder()
			.command(internalPath.absolutePath, "--arg1", "value")
			.directory(context.filesDir)
			.redirectErrorStream(true)
			.start()

			// Read output (Logcat)
			process.inputStream.bufferedReader().forEachLine { line ->
				Log.d("SlipstreamBin", line)
			}
		} catch (e: Exception) {
			Log.e("SlipstreamBin", "Failed to run binary", e)
		}
	}
}

class MainApp : Application() {
	override fun onCreate() {
		super.onCreate()
		val channel = NotificationChannel(
			notifChannelID_audioService,
			"Audio service",
			NotificationManager.IMPORTANCE_MIN,
		)
		val notifMgr = getSystemService(NOTIFICATION_SERVICE) as NotificationManager
		notifMgr.createNotificationChannel(channel)
	}
}

class AudioService : Service() {

	enum class Action {
		START,
		STOP,
	}

	override fun onBind(p0: Intent?): IBinder? {
		//TODO("Not yet implemented")
		return null
	}

	override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
		when (intent?.action) {
			Action.START.toString() -> start()
			Action.STOP.toString() -> stopSelf()
		}
		return super.onStartCommand(intent, flags, startId)
	}

	private fun start() {
		val notif = NotificationCompat.Builder(this, notifChannelID_audioService)
			.setContentTitle("PhoneMic")
			.setContentText("Audio Service Running")
			.setSmallIcon(R.drawable.ic_launcher_foreground)
			.build()
		val svcId = 1
		if (Build.VERSION.SDK_INT >= sdk34_UpsideDownCake) {
			startForeground(
				svcId,
				notif,
				ServiceInfo.FOREGROUND_SERVICE_TYPE_MICROPHONE
			)
		} else {
			startForeground(svcId, notif)
		}
	}
}

